{
  "version": 3,
  "routes": [
    {
      "src": "^/uploads/(.*)$",
      "dest": "/uploads/$1"
    },
    {
      "src": "^/image/(.*)$",
      "dest": "/image/$1"
    },
    {
      "src": "^/logo/(.*)$",
      "dest": "/logo/$1"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "dist/index.js"
    }
  ],
  "framework": {
    "version": "15.1.7"
  },
  "crons": []
}
