# Database — Neon PostgreSQL (use direct connection, not pooler for unpooled)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dapurdekaka?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@your-neon-host.neon.tech/dapurdekaka?sslmode=require

# Auth
AUTH_SECRET=your-random-32-char-secret-here
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Midtrans
MIDTRANS_SERVER_KEY=your-midtrans-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# RajaOngkir
RAJAONGKIR_API_KEY=your-rajaongkir-api-key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@dapurdekaka.com

# Minimax AI
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=62812xxxxxxxx

# Seed (dev only)
SEED_ADMIN_EMAIL=bashara@dapurdekaka.com
SEED_ADMIN_PASSWORD=your-strong-dev-password

# Cron Authentication
CRON_SECRET=your-random-cron-secret-here