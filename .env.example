# Required environment variables for Vercel deployment
DATABASE_URL=          # PostgreSQL connection string (POSTGRES_URL for @vercel/postgres)
SESSION_SECRET=         # 32+ character secret for iron-session encryption
VITE_TINYMCE_API_KEY=  # TinyMCE API key (client-side, VITE_ prefix)
BLOB_READ_WRITE_TOKEN= # Vercel Blob read/write token for file uploads
