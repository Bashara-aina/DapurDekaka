{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "regions": ["sin1"],
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x",
      "includeFiles": "./lib/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|sitemap.xml|favicon\\.ico|assets/|logo/|asset/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}